{
  "name": "blinkbudget",
  "version": "1.42",
  "type": "module",
  "description": "Making expense tracking effortless, all in 3 moves.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "lint:css:fix": "stylelint \"src/styles/**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "yarn run lint && yarn run lint:css && yarn run format:check && yarn run validate-docs",
    "fix": "yarn run lint:fix && yarn run lint:css:fix && yarn run format && yarn run validate-docs:stats && yarn run validate-docs",
    "validate-env": "node config/validate-env.cjs",
    "validate-docs": "node scripts/validate-docs.js",
    "validate-docs:stats": "node scripts/validate-docs.js --stats"
  },
  "keywords": [],
  "author": "Krasen Ivanov",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=26.0.0",
    "yarn": ">=4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^8.0.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "postcss-calc": "^10.1.1",
    "postcss-color-functional-notation": "^8.0.5",
    "postcss-custom-media": "^12.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.3.1",
    "postcss-sorting": "^10.0.0",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.48.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "workbox-window": "^7.4.1"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "firebase": "^12.15.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "serialize-javascript": "^7.0.3",
    "vite": "npm:rolldown-vite@8.0.16"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "quoteProps": "as-needed",
    "bracketSameLine": false,
    "proseWrap": "preserve"
  },
  "packageManager": "yarn@4.17.0"
}
