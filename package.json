{
  "name": "blinkbudget",
  "version": "1.30",
  "type": "module",
  "description": "Making expense tracking effortless, all in 3 moves.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "lint:css:fix": "stylelint \"src/styles/**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "yarn run lint && yarn run lint:css && yarn run format:check",
    "fix": "yarn run lint:fix && yarn run lint:css:fix && yarn run format",
    "validate-env": "node config/validate-env.cjs"
  },
  "keywords": [],
  "author": "Krasen Ivanov",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.2",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "postcss-calc": "^10.1.1",
    "postcss-color-functional-notation": "^8.0.2",
    "postcss-custom-media": "^12.0.1",
    "postcss-import": "^16.1.1",
    "postcss-logical-properties": "^0.0.4",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.0",
    "postcss-sorting": "^9.1.0",
    "prettier": "^3.8.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^36.0.1",
    "terser": "^5.46.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "firebase": "^12.10.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "serialize-javascript": "^7.0.3"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "quoteProps": "as-needed",
    "bracketSameLine": false,
    "proseWrap": "preserve"
  }
}
